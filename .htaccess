# ============================================================
# LSF Generator — Configuration Apache
# Fichier : .htaccess
# Réalisé par IntA11Y - Solutions
# ============================================================
#
# Ce fichier configure le serveur web Apache pour :
# 1. Protéger les fichiers sensibles
# 2. Activer la compression (performance)
# 3. Configurer le cache navigateur
# 4. Améliorer la sécurité (headers HTTP)
#
# COMPATIBILITÉ : Apache 2.4+
# IONOS / OVH / PlanetHoster : activez mod_rewrite dans le panneau
# ============================================================

# --------------------------------------------------------------
# SÉCURITÉ — Protéger les fichiers sensibles
# --------------------------------------------------------------

# Interdit l'accès direct au dossier de configuration
<IfModule mod_authz_core.c>
    <FilesMatch "^db-config\.php$">
        Require all denied
    </FilesMatch>
</IfModule>

# Interdit l'accès aux fichiers de sauvegarde et aux fichiers cachés
<FilesMatch "(\.bak|\.sql|\.log|~|\.git)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# --------------------------------------------------------------
# HEADERS DE SÉCURITÉ HTTP
# Protège contre les attaques XSS, clickjacking, etc.
# --------------------------------------------------------------
<IfModule mod_headers.c>
    # Protection contre le clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Protection XSS (navigateurs anciens)
    Header always set X-XSS-Protection "1; mode=block"
    
    # Empêche le "MIME sniffing"
    Header always set X-Content-Type-Options "nosniff"
    
    # Politique de référent stricte
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy
    # Permet les ressources Google Fonts, CDN fonts, et notre API
    # Polices en data: autorisées (OpenDyslexic via cdnfonts charge en base64)
    # 'unsafe-inline' pour les scripts inline mineurs (console.info, etc.)
    Header always set Content-Security-Policy "default-src 'self'; style-src 'self' https://fonts.googleapis.com https://fonts.cdnfonts.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com https://fonts.cdnfonts.com data:; script-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; media-src 'self' https: blob:; frame-src 'self' https://www.elix-lsf.fr; connect-src 'self' https://www.elix-lsf.fr https://www.spreadthesign.com https://fonts.googleapis.com https://fonts.cdnfonts.com;"
    
    # Supprime l'en-tête "Server" (masque la version Apache)
    Header always unset Server
</IfModule>

# --------------------------------------------------------------
# COMPRESSION GZIP — Réduit la taille des fichiers transférés
# Améliore significativement les performances
# --------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --------------------------------------------------------------
# CACHE NAVIGATEUR — Mémorise les ressources statiques
# Évite de re-télécharger les fichiers à chaque visite
# --------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Polices : 1 an (elles ne changent jamais)
    ExpiresByType font/woff2             "access plus 1 year"
    ExpiresByType font/woff              "access plus 1 year"
    
    # CSS & JS : 1 semaine
    ExpiresByType text/css               "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    
    # Images : 1 mois
    ExpiresByType image/jpeg             "access plus 1 month"
    ExpiresByType image/png              "access plus 1 month"
    ExpiresByType image/svg+xml          "access plus 1 month"
    ExpiresByType image/webp             "access plus 1 month"
    
    # HTML : pas de cache (toujours frais)
    ExpiresByType text/html              "access plus 0 seconds"
    
    # API JSON : pas de cache navigateur (géré par MySQL)
    ExpiresByType application/json       "access plus 0 seconds"
</IfModule>

# --------------------------------------------------------------
# TYPES MIME — Associe extensions et types de contenu
# --------------------------------------------------------------
<IfModule mod_mime.c>
    AddType application/javascript      .js
    AddType text/css                    .css
    AddType font/woff2                  .woff2
    AddType font/woff                   .woff
    AddType image/webp                  .webp
    AddType image/svg+xml               .svg
</IfModule>

# --------------------------------------------------------------
# PAGE D'ERREUR PERSONNALISÉE
# --------------------------------------------------------------
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html
ErrorDocument 500 /index.html

# --------------------------------------------------------------
# ENCODAGE PAR DÉFAUT
# --------------------------------------------------------------
AddDefaultCharset UTF-8
